# --- Python 运行缓存 ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- VS Code 个人配置 ---
# 注意：如果你想让别人也看到你的 settings.json 模板，可以不屏蔽 .vscode/
# 但建议屏蔽其中的个人状态文件
.vscode/pythonAnalysisSymbolCache/
.vscode/project_stats.json

# --- QGIS 运行时产生的临时文件 ---
*.log
*.aux
*.qix
*.qlr
*.qml.bak

# --- 数据文件 (建议屏蔽，防止上传巨大的 .tif 或 .shp) ---
# 如果你想分享测试数据，可以专门建个 data/ 文件夹并在里面放个 Readme
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.tif
*.tiff
*.adf
*.idm
*.ind

# --- 操作系统临时文件 ---
.DS_Store
Thumbs.db

# --- 本地启动脚本 (如果你不想暴露自己的绝对路径) ---
# vscode_qgis_V2.bat
