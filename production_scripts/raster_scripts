import os
import sys
import time  # 引入计时库

# 1. 设置基础路径
qgis_base = r"D:\GIS\QGIS3.40"

# 2. 路径引导补丁：解决 ModuleNotFoundError
python_path = os.path.join(qgis_base, "apps", "qgis-ltr", "python")
plugins_path = os.path.join(python_path, "plugins")
for path in [python_path, plugins_path]:
    if path not in sys.path:
        sys.path.append(path)

# 3. DLL 加载修复：解决 Windows 环境下独立运行的加载错误
os.add_dll_directory(os.path.join(qgis_base, "bin"))
os.add_dll_directory(os.path.join(qgis_base, "apps", "qgis-ltr", "bin"))
os.add_dll_directory(os.path.join(qgis_base, "apps", "Qt5", "bin"))

# 4. 导入核心类（必须在 DLL 修复之后）
from qgis.core import QgsApplication, QgsVectorLayer, QgsRasterLayer
import processing
from processing.core.Processing import Processing

# 5. 实例化 QGIS 应用程序
qgs = QgsApplication([], False)
qgs.initQgis()

# 6. 强制语法闭环：确保资源始终能被释放
try:
    # 记录起始时间
    start_time = time.perf_counter()
    
    # 必须在此处初始化算法框架
    Processing.initialize()
    
    # 路径设定 (使用原始字符串)
    mask_layer_path = r"D:\gis\测试数据\获嘉县zone.shp"
    raster_layer_path = r"D:\gis\data\dem_250m\hdr.adf"
    output_path = r"D:\gis\测试数据\clipped_dem.tif"

    # --- 流程显示：任务开始 ---
    print(f"🔍 正在执行裁剪：使用 {os.path.basename(mask_layer_path)} 裁剪栅格...")
    
    # 加载数据并验证有效性
    mask_layer = QgsVectorLayer(mask_layer_path, "mask", "ogr")
    raster_layer = QgsRasterLayer(raster_layer_path, "raster")

    if mask_layer.isValid() and raster_layer.isValid():
        # 执行裁剪 (禁止修改原数据颜色与设定)
        params = {
            'INPUT': raster_layer,
            'MASK': mask_layer,
            'NODATA': None,  # 保持原数据 NoData 设定
            'CROP_TO_CUTLINE': True,
            'KEEP_RESOLUTION': True,
            'OUTPUT': output_path
        }
        
        # 调用 GDAL 裁剪算法
        processing.run("gdal:cliprasterbymasklayer", params)
        
        # 计算总耗时
        end_time = time.perf_counter()
        elapsed = end_time - start_time
        
        # --- 流程显示：结果反馈 ---
        print("-" * 30)
        print(f"✅ 裁剪完成！")
        print(f"⏱️ 任务总耗时: {elapsed:.2f} 秒")
        print(f"💾 结果已保存至: {output_path}")
        print("-" * 30)
    else:
        print("❌ 错误：无法读取输入文件，请检查路径有效性。")

except Exception as e:
    print(f"💥 运行过程中发生错误: {e}")

finally:
    # 7. 退出 QGIS，释放 RTX 4060 显存与 DLL 进程
    qgs.exitQgis()
    print("🔔 QGIS 资源已成功释放。")
